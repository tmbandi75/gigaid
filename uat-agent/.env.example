# UAT Agent Configuration
# Copy this file to .env and fill in values

# Base URL of the running GigAid application
UAT_BASE_URL=http://localhost:5000

# Test account credentials (create via /api/auth or signup flow)
UAT_TEST_EMAIL=uat-test@gigaid.ai
UAT_TEST_PASSWORD=UatTest123!

# Stripe test card number (default: Visa test card)
STRIPE_TEST_CARD=4242424242424242

# Run browser in headless mode (true/false)
UAT_HEADLESS=true

# Slow down actions by N milliseconds (useful for debugging)
UAT_SLOW_MO=0

# Default timeout for waits/assertions in milliseconds
UAT_TIMEOUT=30000
