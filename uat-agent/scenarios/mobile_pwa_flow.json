{
  "name": "Mobile PWA Flow",
  "description": "Tests the mobile-first experience including navigation, dashboard, and key actions on a mobile viewport",
  "viewport": "mobile",
  "tags": ["mobile", "pwa", "navigation", "critical"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials on mobile"
    },
    {
      "action": "wait",
      "timeout": 5000,
      "description": "Wait for post-login page to load"
    },
    {
      "action": "goto",
      "url": "/jobs",
      "description": "Navigate to jobs page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-jobs']",
      "timeout": 10000,
      "description": "Wait for jobs page to render"
    },
    {
      "action": "goto",
      "url": "/leads",
      "description": "Navigate to leads page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-leads']",
      "timeout": 10000,
      "description": "Wait for leads page to render"
    },
    {
      "action": "goto",
      "url": "/invoices",
      "description": "Navigate to invoices page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-invoices']",
      "timeout": 10000,
      "description": "Wait for invoices page to render"
    },
    {
      "action": "goto",
      "url": "/more",
      "description": "Navigate to More page (settings menu)"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-more']",
      "timeout": 10000,
      "description": "Wait for More page to render"
    },
    {
      "action": "goto",
      "url": "/pricing",
      "description": "Navigate to pricing page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-pricing']",
      "timeout": 10000,
      "description": "Wait for pricing page to render"
    }
  ],
  "assertions": [
    {
      "type": "url",
      "expected": "/pricing",
      "description": "Should be on the pricing page"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='page-pricing']",
      "description": "Pricing page container should be visible"
    }
  ]
}
