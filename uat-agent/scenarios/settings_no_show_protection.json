{
  "name": "Settings No-Show Protection",
  "description": "Tests the no-show protection toggle and deposit percent selector in Settings",
  "viewport": "desktop",
  "tags": ["more", "settings", "no-show", "deposit"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "goto",
      "url": "/settings",
      "description": "Navigate to Settings page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-settings']",
      "timeout": 10000,
      "description": "Wait for Settings page to render"
    },
    {
      "action": "wait",
      "selector": "[data-testid='switch-no-show-protection']",
      "timeout": 5000,
      "description": "Wait for no-show protection toggle"
    },
    {
      "action": "wait",
      "selector": "[data-testid='select-deposit-percent']",
      "timeout": 5000,
      "description": "Wait for deposit percent selector"
    },
    {
      "action": "wait",
      "selector": "[data-testid='switch-show-reviews']",
      "timeout": 5000,
      "description": "Wait for show reviews toggle"
    },
    {
      "action": "wait",
      "selector": "[data-testid='switch-public-estimation']",
      "timeout": 5000,
      "description": "Wait for public estimation toggle"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='page-settings']",
      "description": "Settings page should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='switch-no-show-protection']",
      "description": "No-show protection toggle should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='select-deposit-percent']",
      "description": "Deposit percent selector should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='switch-show-reviews']",
      "description": "Show reviews toggle should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='switch-public-estimation']",
      "description": "Public estimation toggle should be visible"
    }
  ]
}
