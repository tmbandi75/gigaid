{
  "name": "Book and Pay",
  "description": "Tests the full booking and payment flow: login, create job, send invoice, and verify invoice status",
  "viewport": "desktop",
  "tags": ["booking", "payment", "revenue", "critical"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "timeout": 5000,
      "description": "Wait for post-login page to load"
    },
    {
      "action": "goto",
      "url": "/jobs",
      "description": "Navigate to jobs page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-jobs']",
      "timeout": 10000,
      "description": "Wait for jobs page to render"
    },
    {
      "action": "create_job",
      "value": "UAT Plumbing Repair",
      "description": "Create a new test job"
    },
    {
      "action": "wait",
      "timeout": 3000,
      "description": "Wait for job creation to complete"
    },
    {
      "action": "goto",
      "url": "/invoices",
      "description": "Navigate to invoices page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-invoices']",
      "timeout": 10000,
      "description": "Wait for invoices page to render"
    },
    {
      "action": "send_invoice",
      "description": "Create and send an invoice"
    },
    {
      "action": "wait",
      "timeout": 3000,
      "description": "Wait for invoice to be sent"
    }
  ],
  "assertions": [
    {
      "type": "url",
      "expected": "/invoices",
      "description": "Should be on the invoices page"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='page-invoices'], [data-testid='page-invoice-form']",
      "description": "Invoices or invoice form page should be visible"
    }
  ]
}
