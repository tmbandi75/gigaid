{
  "name": "Settings Delete Account Dialog",
  "description": "Tests that the delete account button and confirmation dialog render on the Settings page",
  "viewport": "desktop",
  "tags": ["more", "settings", "delete-account"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "goto",
      "url": "/settings",
      "description": "Navigate to Settings page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-settings']",
      "timeout": 10000,
      "description": "Wait for Settings page to render"
    },
    {
      "action": "wait",
      "selector": "[data-testid='button-delete-account']",
      "timeout": 10000,
      "description": "Wait for delete account button to exist in DOM"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='page-settings']",
      "description": "Settings page should be visible"
    }
  ]
}
