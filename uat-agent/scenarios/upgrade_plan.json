{
  "name": "Upgrade Plan",
  "description": "Tests the subscription upgrade flow from Free to Pro tier via the pricing page",
  "viewport": "desktop",
  "tags": ["subscription", "pricing", "revenue", "critical"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "timeout": 5000,
      "description": "Wait for post-login page to load"
    },
    {
      "action": "goto",
      "url": "/pricing",
      "description": "Navigate to pricing page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-pricing']",
      "timeout": 10000,
      "description": "Wait for pricing page to render"
    },
    {
      "action": "upgrade_plan",
      "description": "Click upgrade button on Pro plan"
    },
    {
      "action": "wait",
      "timeout": 5000,
      "description": "Wait for Stripe checkout or upgrade modal"
    }
  ],
  "assertions": [
    {
      "type": "url",
      "expected": "/pricing",
      "description": "Should be on the pricing page"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='page-pricing']",
      "description": "Pricing page container should be visible"
    }
  ]
}
