{
  "name": "Notify Clients Event Selection",
  "description": "Tests selecting an event type and verifying message composition fields on the Notify Clients page",
  "viewport": "mobile",
  "tags": ["more", "notify", "events", "sms"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "goto",
      "url": "/notify-clients",
      "description": "Navigate to Notify Clients page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-notify-clients']",
      "timeout": 10000,
      "description": "Wait for Notify Clients page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='button-event-seasonal_promo'], [data-testid='button-event-availability_update'], [data-testid='button-event-new_service']",
      "description": "Click an event type button",
      "optional": true
    },
    {
      "action": "wait",
      "timeout": 2000,
      "description": "Wait for event selection to process"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='page-notify-clients']",
      "description": "Notify Clients page should be visible"
    }
  ]
}
