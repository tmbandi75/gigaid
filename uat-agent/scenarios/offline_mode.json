{
  "name": "Offline Mode",
  "description": "Tests that key app routes load correctly, verifying offline-ready page rendering across the application",
  "viewport": "mobile",
  "tags": ["offline", "pwa", "resilience"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "timeout": 5000,
      "description": "Wait for post-login page to load"
    },
    {
      "action": "goto",
      "url": "/dashboard",
      "description": "Navigate to dashboard"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-dashboard'], [data-testid='page-game-plan']",
      "timeout": 10000,
      "description": "Wait for dashboard to render"
    },
    {
      "action": "goto",
      "url": "/jobs",
      "description": "Navigate to jobs"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-jobs']",
      "timeout": 10000,
      "description": "Wait for jobs page to render"
    },
    {
      "action": "goto",
      "url": "/leads",
      "description": "Navigate to leads"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-leads']",
      "timeout": 10000,
      "description": "Wait for leads page to render"
    },
    {
      "action": "goto",
      "url": "/invoices",
      "description": "Navigate to invoices"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-invoices']",
      "timeout": 10000,
      "description": "Wait for invoices page to render"
    },
    {
      "action": "goto",
      "url": "/voice-notes",
      "description": "Navigate to voice notes"
    },
    {
      "action": "wait",
      "selector": "[data-testid='voice-notes-page']",
      "timeout": 10000,
      "description": "Wait for voice notes page to render"
    },
    {
      "action": "goto",
      "url": "/profile",
      "description": "Navigate to profile"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-profile'], [data-testid='card-profile']",
      "timeout": 10000,
      "description": "Wait for profile page to render"
    }
  ],
  "assertions": [
    {
      "type": "url",
      "expected": "/profile",
      "description": "Should be on the profile page"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='page-profile'], [data-testid='card-profile']",
      "description": "Profile page should be visible"
    }
  ]
}
