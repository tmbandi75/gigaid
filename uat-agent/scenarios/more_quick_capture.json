{
  "name": "Quick Capture Page",
  "description": "Tests navigating to Quick Capture from the More page and verifying the lead capture form renders",
  "viewport": "mobile",
  "tags": ["more", "quick-capture", "leads"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "goto",
      "url": "/more",
      "description": "Navigate to More page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-more']",
      "timeout": 10000,
      "description": "Wait for More page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='menu-quick-capture']",
      "description": "Click Quick Capture menu item"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-share-capture']",
      "timeout": 10000,
      "description": "Wait for Quick Capture page to render"
    },
    {
      "action": "wait",
      "selector": "[data-testid='input-shared-text'], [data-testid='button-manual-entry']",
      "timeout": 5000,
      "description": "Wait for text input or manual entry button"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='page-share-capture']",
      "description": "Quick Capture page should be visible"
    }
  ]
}
