{
  "name": "Auto Follow-Ups Page",
  "description": "Tests navigating to Auto Follow-Ups from the More page and verifying rule cards and save button",
  "viewport": "mobile",
  "tags": ["more", "follow-ups", "automation"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "goto",
      "url": "/more",
      "description": "Navigate to More page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-more']",
      "timeout": 10000,
      "description": "Wait for More page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='menu-auto-follow-ups']",
      "description": "Click Auto Follow-Ups menu item"
    },
    {
      "action": "wait",
      "selector": "[data-testid='text-page-title']",
      "timeout": 10000,
      "description": "Wait for page title to render"
    },
    {
      "action": "wait",
      "selector": "[data-testid='button-save-rules']",
      "timeout": 5000,
      "description": "Wait for save rules button"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='text-page-title']",
      "description": "Page title should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='button-save-rules']",
      "description": "Save rules button should be visible"
    }
  ]
}
