{
  "name": "Login Page",
  "description": "Tests the login page renders correctly with all form elements, toggle to signup mode, and successful authentication",
  "viewport": "mobile",
  "tags": ["auth", "login", "form"],
  "steps": [
    {
      "action": "goto",
      "url": "/",
      "description": "Navigate to login page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='splash-page']",
      "timeout": 15000,
      "description": "Wait for login page to render (including service worker reload)"
    },
    {
      "action": "wait",
      "selector": "[data-testid='input-email']",
      "timeout": 5000,
      "description": "Wait for email input to be visible"
    },
    {
      "action": "wait",
      "selector": "[data-testid='input-password']",
      "timeout": 5000,
      "description": "Wait for password input to be visible"
    },
    {
      "action": "wait",
      "selector": "[data-testid='button-email-submit']",
      "timeout": 5000,
      "description": "Wait for submit button to be visible"
    },
    {
      "action": "wait",
      "selector": "[data-testid='button-toggle-auth-mode']",
      "timeout": 5000,
      "description": "Wait for toggle auth mode button to be visible"
    },
    {
      "action": "click",
      "selector": "[data-testid='button-toggle-auth-mode']",
      "description": "Switch to signup mode"
    },
    {
      "action": "wait",
      "selector": "[data-testid='input-confirm-password']",
      "timeout": 5000,
      "description": "Wait for confirm password field to appear in signup mode"
    },
    {
      "action": "click",
      "selector": "[data-testid='button-toggle-auth-mode']",
      "description": "Switch back to login mode"
    },
    {
      "action": "wait",
      "timeout": 1000,
      "description": "Wait for mode toggle animation"
    },
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard after successful login"
    }
  ],
  "assertions": [
    {
      "type": "url",
      "expected": "/dashboard",
      "description": "Should be on the dashboard after login"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "description": "Dashboard page should be visible"
    }
  ]
}
