{
  "name": "Churn Recovery",
  "description": "Tests the subscription restore and churn recovery flow for returning users",
  "viewport": "mobile",
  "tags": ["churn", "retention", "subscription"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "timeout": 5000,
      "description": "Wait for post-login page to load"
    },
    {
      "action": "goto",
      "url": "/settings",
      "description": "Navigate to settings page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-settings']",
      "timeout": 10000,
      "description": "Wait for settings page to render"
    },
    {
      "action": "wait",
      "selector": "[data-testid='card-subscription-settings'], [data-testid='card-restore-access']",
      "timeout": 10000,
      "description": "Wait for subscription section to load"
    },
    {
      "action": "click",
      "selector": "[data-testid='button-restore-access']",
      "description": "Click restore access button",
      "optional": true
    },
    {
      "action": "wait",
      "timeout": 5000,
      "description": "Wait for restore result"
    }
  ],
  "assertions": [
    {
      "type": "url",
      "expected": "/settings",
      "description": "Should be on the settings page"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='page-settings']",
      "description": "Settings page container should be visible"
    }
  ]
}
