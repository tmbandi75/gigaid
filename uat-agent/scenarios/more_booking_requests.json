{
  "name": "Booking Requests Page",
  "description": "Tests navigating to Booking Requests from the More page, verifying filter options and page rendering",
  "viewport": "mobile",
  "tags": ["more", "booking", "requests"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "goto",
      "url": "/more",
      "description": "Navigate to More page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-more']",
      "timeout": 10000,
      "description": "Wait for More page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='menu-booking-requests']",
      "description": "Click Booking Requests menu item"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-booking-requests']",
      "timeout": 10000,
      "description": "Wait for Booking Requests page to render"
    },
    {
      "action": "wait",
      "selector": "[data-testid='filter-all']",
      "timeout": 5000,
      "description": "Wait for All filter button"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='page-booking-requests']",
      "description": "Booking Requests page should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='filter-all']",
      "description": "All filter should be visible"
    }
  ]
}
