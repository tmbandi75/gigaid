{
  "name": "Navigation Sidebar",
  "description": "Tests that all main sidebar navigation links route correctly to their respective pages",
  "viewport": "desktop",
  "tags": ["navigation", "sidebar", "routing"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "wait",
      "selector": "[data-testid='sidebar-desktop']",
      "timeout": 5000,
      "description": "Wait for sidebar to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='sidebar-nav-jobs']",
      "description": "Click Jobs in sidebar"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-jobs']",
      "timeout": 10000,
      "description": "Wait for jobs page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='sidebar-nav-new requests']",
      "description": "Click New Requests (Leads) in sidebar"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-leads']",
      "timeout": 10000,
      "description": "Wait for leads page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='sidebar-nav-get paid']",
      "description": "Click Get Paid (Invoices) in sidebar"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-invoices']",
      "timeout": 10000,
      "description": "Wait for invoices page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='sidebar-tool-voice-notes']",
      "description": "Click Voice Notes in sidebar"
    },
    {
      "action": "wait",
      "selector": "[data-testid='voice-notes-page']",
      "timeout": 10000,
      "description": "Wait for voice notes page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='sidebar-tool-ai-tools']",
      "description": "Click AI Tools in sidebar"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-ai-tools']",
      "timeout": 10000,
      "description": "Wait for AI tools page to render"
    },
    {
      "action": "click",
      "selector": "[data-testid='sidebar-nav-game plan']",
      "description": "Click Game Plan (Dashboard) in sidebar to go back"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 10000,
      "description": "Wait for dashboard to render again"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "description": "Dashboard should be visible after navigating back"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='sidebar-desktop']",
      "description": "Sidebar should remain visible throughout"
    }
  ]
}
