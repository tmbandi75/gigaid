{
  "name": "More Page Desktop Layout",
  "description": "Tests the More page renders correctly in desktop viewport with desktop header and profile card",
  "viewport": "desktop",
  "tags": ["more", "desktop", "layout"],
  "steps": [
    {
      "action": "login",
      "description": "Log in with test credentials"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-game-plan'], [data-testid='page-dashboard']",
      "timeout": 15000,
      "description": "Wait for dashboard to load"
    },
    {
      "action": "goto",
      "url": "/more",
      "description": "Navigate to More page"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-more']",
      "timeout": 10000,
      "description": "Wait for More page to render"
    },
    {
      "action": "wait",
      "selector": "[data-testid='page-title']",
      "timeout": 5000,
      "description": "Wait for desktop page title"
    },
    {
      "action": "wait",
      "selector": "[data-testid='card-profile-desktop']",
      "timeout": 5000,
      "description": "Wait for desktop profile card"
    },
    {
      "action": "wait",
      "selector": "[data-testid='badge-user-plan-desktop']",
      "timeout": 5000,
      "description": "Wait for desktop plan badge"
    },
    {
      "action": "wait",
      "selector": "[data-testid='toggle-dark-mode']",
      "timeout": 5000,
      "description": "Wait for dark mode toggle"
    },
    {
      "action": "wait",
      "selector": "[data-testid='logout-button']",
      "timeout": 5000,
      "description": "Wait for logout button"
    }
  ],
  "assertions": [
    {
      "type": "element_visible",
      "selector": "[data-testid='page-more']",
      "description": "More page should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='page-title']",
      "description": "Desktop page title should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='card-profile-desktop']",
      "description": "Desktop profile card should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='badge-user-plan-desktop']",
      "description": "Desktop plan badge should be visible"
    },
    {
      "type": "element_visible",
      "selector": "[data-testid='logout-button']",
      "description": "Logout button should be visible"
    }
  ]
}
