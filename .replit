modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["glib", "nss", "nspr", "at-spi2-atk", "cups", "libdrm", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXrandr", "mesa", "expat", "xorg.libxcb", "alsa-lib", "pango", "cairo", "xorg.libX11", "xorg.libXext", "xorg.libXfixes", "dbus", "libxkbcommon"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "safe-price-scan"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "safe-price-eslint"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "safe-price-scan"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx jest --selectProjects lib --testPathPatterns noRawPriceTemplates --colors --no-cache"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "safe-price-eslint"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx eslint --config eslint.safeprice.config.js 'client/src/**/*.{ts,tsx}' 'server/**/*.{ts,tsx}' 'shared/**/*.{ts,tsx}'"

[agent]
integrations = ["javascript_object_storage:2.0.0", "stripe:2.0.0", "twilio:1.0.0"]

[userenv]

[userenv.shared]
FIREBASE_PROJECT_ID = "gigaid-9c982"
FIREBASE_CLIENT_EMAIL = "firebase-adminsdk-fbsvc@gigaid-9c982.iam.gserviceaccount.com"
STRIPE_ENABLED = "true"
VITE_STRIPE_ENABLED = "true"
VITE_FIREBASE_AUTH_DOMAIN = "gigaid-9c982.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "gigaid-9c982"
VITE_FIREBASE_STORAGE_BUCKET = "gigaid-9c982.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "1028384687867"
VITE_FIREBASE_APP_ID = "1:1028384687867:web:4fa0509917f178cc80d25e"
VITE_FIREBASE_API_KEY = "AIzaSyBdyS79wNb_GBqARmJmzrBr2ZsdsC_51l8"
VITE_REVENUECAT_API_KEY_IOS = "appl_smduSoTpQpwjvuhvuTryLiJIhRG"
